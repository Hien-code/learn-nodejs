extends ../../layouts/default.pug
include ../../mixins/filterStatus.pug

block main
  h1 Trang sản phẩm

  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body.container-fluid
      .row
        .col-8
          +filterStatus(filterStatus)
        .col-4
          form(id="form-search")
            .input-group
              input(type="text", placeholder="Nhập từ khóa", name="keyword", class="form-control", value = keyword)
              .input-group-append
                button(class="btn btn-success", type="submit") Tìm

  .card.mb-3
    .card-header Danh sách sản phẩm
    .card-body
      table.table.table-hover.table-sm
        thead
          tr
            th STT
            th Hình ảnh
            th Tiêu đề
            th Giá
            th Trạng thái
            th Hành động

        tbody
          each item, index in product
            tr
              td #{index + 1}
              td
                img(
                  src=item.thumbnail,
                  alt=item.title,
                  class="img-thumbnail"
                )
              td #{item.title}
              td #{item.price} $
              td
                if item.status == "active"
                  span(class="badge badge-success") Active
                else
                  span(class="badge badge-danger") Inactive
              td
                .d-flex.justify-content-center
                  button(type="button", class="btn-edit") Edit
                  button(type="button", class="btn-delete") Delete

  nav
    ul(class="pagination")
      li(class="page-item")
        button(class="page-link" button-pagination = 1) First
      if(pagination.currentPage > 1)
        li(class="page-item" button-pagination = pagination.currentPage - 1)
          button(class="page-link") <
      - let startPage = Math.max(1, pagination.currentPage - 1)
      - let endPage = Math.min(pagination.currentPage + 1, pagination.totalPages)
      - for(let i = startPage; i <= endPage; i++)
          li(class=`page-item ${pagination.currentPage == i ? "active" : "" }`)
            button(class="page-link" button-pagination = i) #{i}
      if(pagination.currentPage < pagination.totalPages)
        li(class="page-item")
          button(class="page-link" button-pagination = pagination.currentPage + 1) >
      li(class="page-item")
        button(class="page-link" button-pagination = pagination.totalPages) Last